      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "InfluxDB"
          },
          "query": "from(bucket: \"processes\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"procstat\")\n  |> filter(fn: (r) => r[\"_field\"] == \"cpu_usage\")\n  |> filter(fn: (r) => contains(value: r.host, set: ${machines:json}))\n  |> group(columns: [\"host\", \"process_name\", \"pid\"])\n  |> last()\n  |> filter(fn: (r) => r[\"_value\"] > 0.1)\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 20)\n  |> map(fn: (r) => ({ \n    Host: r.host,\n    Process: r.process_name,\n    PID: string(v: r.pid),\n    \"CPU %\": string(v: r._value) + \"%\"\n  }))\n  |> drop(columns: [\"_start\", \"_stop\", \"_time\", \"_value\", \"_field\", \"_measurement\"])",
          "refId": "A"
        }
      ],
